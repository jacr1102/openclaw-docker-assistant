# Copy to a shell session or `set -a; source .env; set +a` before running setup.
# Official reference: https://openclaw.im/docs/install/docker

# Where OpenClaw stores config and agent state (default in scripts: ./data/config)
# OPENCLAW_CONFIG_DIR=/absolute/path/to/data/config

# Agent workspace projects (default: ./data/workspace)
# OPENCLAW_WORKSPACE_DIR=/absolute/path/to/data/workspace

# Ports (defaults shown)
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790

# Bind: lan is typical for Docker (default in upstream setup)
# OPENCLAW_GATEWAY_BIND=lan

# Optional: named volume for full container $HOME instead of bind mounts
# OPENCLAW_HOME_VOLUME=openclaw_home

# Optional: extra bind mounts, comma-separated source:target[:opts]
# OPENCLAW_EXTRA_MOUNTS=$HOME/projects:/home/node/projects:rw

# Optional: agent sandbox (needs Docker socket + image build); see upstream docs
# OPENCLAW_SANDBOX=1

# Timezone inside containers (IANA name)
# OPENCLAW_TZ=America/Los_Angeles

# Provider keys are normally set during `onboard` (interactive).
# You can also pass through anything the upstream compose supports, e.g.:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
