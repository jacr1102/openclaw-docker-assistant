# Plantilla local / servidor sin GHCR (imagen construida como openclaw:local).
# Para producción con imagen en GHCR usa deploy/env.prod.example → .env.prod

OPENCLAW_IMAGE=openclaw:local
OPENCLAW_CONFIG_DIR=/opt/openclaw-docker-assistant/data/config
OPENCLAW_WORKSPACE_DIR=/opt/openclaw-docker-assistant/data/workspace
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
