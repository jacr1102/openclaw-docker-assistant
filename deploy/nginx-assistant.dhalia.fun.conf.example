# Nginx — assistant.dhalia.fun → OpenClaw gateway (Docker) on localhost:18789
#
# 1) DNS: A record assistant.dhalia.fun → this server's public IP
# 2) Copy into sites-available and enable:
#    sudo cp deploy/nginx-assistant.dhalia.fun.conf.example /etc/nginx/sites-available/assistant
#    sudo ln -sf /etc/nginx/sites-available/assistant /etc/nginx/sites-enabled/
#
# 3) First-time TLS for this hostname (after DNS propagates):
#    sudo certbot certonly --nginx -d assistant.dhalia.fun
#    Then update ssl_certificate paths below to match certbot output, or use:
#    sudo certbot --nginx -d assistant.dhalia.fun
#    (Certbot can insert SSL blocks; this file matches the manual style used on dhalia.)
#
# 4) Test and reload:
#    sudo nginx -t && sudo systemctl reload nginx
#
# Ensure OpenClaw listens on 127.0.0.1:18789 (docker-compose maps host port 18789).
# If OpenClaw sets gateway.controlUi.allowedOrigins, include https://assistant.dhalia.fun

# --- HTTPS (after certificate exists) ---
server {
    server_name assistant.dhalia.fun;

    location / {
        proxy_pass http://127.0.0.1:18789;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
    }

    listen 443 ssl;
    # Option A: certificate only for assistant (after: certbot certonly --nginx -d assistant.dhalia.fun)
    ssl_certificate /etc/letsencrypt/live/assistant.dhalia.fun/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/assistant.dhalia.fun/privkey.pem;
    # Option B: same multi-domain cert as gift (if you expanded it with: certbot --expand -d gift.dhalia.fun -d assistant.dhalia.fun ...)
    # ssl_certificate /etc/letsencrypt/live/gift.dhalia.fun/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/gift.dhalia.fun/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

# --- HTTP → HTTPS redirect (Certbot often adds similar blocks) ---
server {
    if ($host = assistant.dhalia.fun) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    server_name assistant.dhalia.fun;
    return 404;
}
