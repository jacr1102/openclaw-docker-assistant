# Copy to scripts/mac-node.env or ~/.openclaw-node.env and fill in (never commit real values).
#
#   cp scripts/mac-node.env.example scripts/mac-node.env
#   chmod 600 scripts/mac-node.env

# Tailscale IP of the VPS running OpenClaw (see: tailscale status on the server)
OPENCLAW_GATEWAY_HOST=100.x.x.x

OPENCLAW_GATEWAY_PORT=18789

# Same token as gateway.auth.token on the server (openclaw.json)
OPENCLAW_GATEWAY_TOKEN=paste-gateway-auth-token-here

# Required for ws:// to a tailnet IP (trusted private overlay)
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
