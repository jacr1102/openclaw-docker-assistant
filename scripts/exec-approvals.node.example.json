{
  "version": 1,
  "defaults": {
    "security": "allowlist",
    "ask": "on-miss",
    "askFallback": "deny",
    "autoAllowSkills": true
  },
  "agents": {
    "main": {
      "security": "allowlist",
      "ask": "on-miss",
      "askFallback": "deny",
      "autoAllowSkills": true,
      "allowlist": [
        {
          "id": "a1b2c3d4-e5f6-4789-a012-3456789abcde",
          "pattern": "/opt/homebrew/bin/gh"
        },
        {
          "id": "b2c3d4e5-f6a7-4789-b012-3456789abcde",
          "pattern": "/usr/local/bin/gh"
        },
        {
          "id": "c3d4e5f6-a7b8-4789-c012-3456789abcde",
          "pattern": "/usr/bin/uname"
        }
      ]
    }
  }
}
